{
  "name": "kusto-workbench-viewer",
  "version": "1.0.0",
  "private": true,
  "description": "Read-only web viewer for .kqlx and .kql files hosted on GitHub",
  "scripts": {
    "build": "node esbuild-web.js --production",
    "dev": "node esbuild-web.js && node --env-file=.env dist/server.js",
    "start": "node dist/server.js"
  },
  "dependencies": {
    "express": "^4.21.0",
    "express-session": "^1.18.0",
    "cookie-parser": "^1.4.6"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.0",
    "@types/cookie-parser": "^1.4.7",
    "@types/node": "^20.11.0",
    "esbuild": "^0.24.0",
    "typescript": "^5.5.0"
  }
}
