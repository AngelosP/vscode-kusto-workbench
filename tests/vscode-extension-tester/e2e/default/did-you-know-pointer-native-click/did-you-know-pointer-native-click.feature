    When I move the Dev Host to 0, 0
    And I resize the Dev Host to 900 by 720
    And I execute command "workbench.action.closeSidebar"
    And I execute command "workbench.action.closeAuxiliaryBar"
    And I execute command "workbench.action.closePanel"
    And I wait 2 seconds
    When I execute command "kusto.openTutorials"
    And I wait for "kw-tutorial-viewer" in the webview for 25 seconds
    And I evaluate "(async () => { const sleep = ms => new Promise(resolve => setTimeout(resolve, ms)); const waitFor = async predicate => { for (let attempt = 0; attempt < 160; attempt++) { const value = await predicate(); if (value) return value; await sleep(50); } throw new Error('Timed out setting up compact pointer anchor click probe'); }; const viewer = await waitFor(() => document.querySelector('kw-tutorial-viewer')); const root = viewer.shadowRoot; await waitFor(async () => { await viewer.updateComplete; return viewer.snapshot && root.querySelector('[data-testid=tutorial-viewer-mode-standard]'); }); const base = viewer.snapshot; const source = base.catalog.content.filter(item => item.compatible).slice(0, 3); if (source.length < 3) throw new Error('Need at least three compatible tutorials for pointer probe'); const content = source.map((item, index) => ({ ...item, displayName: index === 0 ? 'Short pointer anchor tip' : index === 1 ? 'Tall pointer anchor tip with a title that wraps onto another line for layout movement' : 'Last pointer anchor tip', unseen: true })); const [shortTip, tallTip] = content; const ids = content.map(item => item.id); const makeSnapshot = selectedTutorialId => ({ ...base, preferredMode: 'compact', selectedCategoryId: shortTip.categoryId, selectedTutorialId, catalog: { ...base.catalog, content: base.catalog.content.map(item => content.find(replacement => replacement.id === item.id) ?? item) }, preferences: base.preferences.map(preference => ({ ...preference, subscribed: true, channel: 'nextFileOpenPopup', unseenCount: 2 })) }); viewer.snapshot = makeSnapshot(shortTip.id); viewer.mode = 'compact'; viewer.selectedCategoryId = shortTip.categoryId; viewer.selectedTutorialId = shortTip.id; viewer.compactSessionTutorialIds = ids; viewer.loadedTutorialId = shortTip.id; viewer.loadingTutorialId = null; viewer.renderedMarkdown = '<p>Short.</p>'; viewer.requestUpdate(); await waitFor(async () => { await viewer.updateComplete; return root.querySelector('[data-testid=tutorial-viewer-mode-compact]') && root.querySelector('[data-testid=tutorial-next]'); }); window.__pointerProbe = { clicks: [], shortId: shortTip.id, tallId: tallTip.id }; root.addEventListener('click', event => { const target = event.composedPath().find(node => node instanceof HTMLElement && (node.dataset?.testid === 'tutorial-next' || node.dataset?.testid === 'tutorial-prev')); if (!target) return; const testid = target.dataset.testid; window.__pointerProbe.clicks.push({ testid, clientX: event.clientX, clientY: event.clientY, before: target.getBoundingClientRect().toJSON() }); const tutorialId = testid === 'tutorial-next' ? tallTip.id : shortTip.id; const markdown = testid === 'tutorial-next' ? '<p>' + Array.from({ length: 18 }, (_, i) => 'Tall line ' + (i + 1) + ' with enough words to make the compact dialog resize.').join('</p><p>') + '</p>' : '<p>Short again.</p>'; setTimeout(() => { window.dispatchEvent(new MessageEvent('message', { data: { type: 'tutorialContent', content: { tutorialId, markdown, source: 'cache', errors: [] } } })); window.dispatchEvent(new MessageEvent('message', { data: { type: 'snapshot', snapshot: makeSnapshot(tutorialId), revision: Date.now() } })); }, 0); }, { capture: true }); return { ready: true, ids, next: root.querySelector('[data-testid=tutorial-next]').getBoundingClientRect().toJSON() }; })()" in the webview for 25 seconds
