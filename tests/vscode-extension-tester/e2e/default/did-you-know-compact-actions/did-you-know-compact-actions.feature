Feature: Did you know compact actions

  Background:
    Given the extension is in a clean state
    When I move the Dev Host to 0, 0
    And I resize the Dev Host to 900 by 720
    And I execute command "workbench.action.closeSidebar"
    And I execute command "workbench.action.closeAuxiliaryBar"
    And I execute command "workbench.action.closePanel"
    And I wait 2 seconds

  Scenario: Compact Got it stays bottom-right when content is empty
    When I execute command "kusto.openTutorials"
    And I wait for "kw-tutorial-viewer" in the webview for 25 seconds
    And I evaluate "(async () => { const sleep = ms => new Promise(resolve => setTimeout(resolve, ms)); const waitFor = async predicate => { for (let attempt = 0; attempt < 120; attempt++) { const value = await predicate(); if (value) return value; await sleep(100); } throw new Error('Timed out waiting for compact action layout'); }; const viewer = await waitFor(() => document.querySelector('kw-tutorial-viewer')); const root = viewer.shadowRoot; await waitFor(async () => { await viewer.updateComplete; return viewer.snapshot && root.querySelector('[data-testid=tutorial-mode-compact]'); }); root.querySelector('[data-testid=tutorial-mode-compact]').click(); await waitFor(async () => { await viewer.updateComplete; return root.querySelector('[data-testid=tutorial-viewer-mode-compact]') && root.querySelector('[data-testid=tutorial-compact-got-it]'); }); const assertFooter = label => { const footer = root.querySelector('.compact-footer'); const browse = root.querySelector('[data-testid=tutorial-mode-standard]'); const gotIt = root.querySelector('[data-testid=tutorial-compact-got-it]'); if (!footer || !browse || !gotIt) throw new Error(label + ': missing compact footer actions'); const footerRect = footer.getBoundingClientRect(); const browseRect = browse.getBoundingClientRect(); const gotRect = gotIt.getBoundingClientRect(); if (gotRect.left < browseRect.right - 1) throw new Error(label + ': Got it should be to the right of Browse all. browse=' + JSON.stringify(browseRect.toJSON()) + ' got=' + JSON.stringify(gotRect.toJSON())); if (footerRect.right - gotRect.right > 24) throw new Error(label + ': Got it is not near the footer right edge. footer=' + JSON.stringify(footerRect.toJSON()) + ' got=' + JSON.stringify(gotRect.toJSON())); if (footerRect.bottom - gotRect.bottom > 16) throw new Error(label + ': Got it is not anchored in the footer bottom area. footer=' + JSON.stringify(footerRect.toJSON()) + ' got=' + JSON.stringify(gotRect.toJSON())); return { footer: footerRect.toJSON(), browse: browseRect.toJSON(), gotIt: gotRect.toJSON() }; }; const contentLayout = assertFooter('content'); const emptySnapshot = () => ({ ...viewer.snapshot, selectedTutorialId: undefined, catalog: { ...viewer.snapshot.catalog, content: viewer.snapshot.catalog.content.map(tutorial => ({ ...tutorial, unseen: false })) }, preferences: viewer.snapshot.preferences.map(preference => ({ ...preference, unseenCount: 0 })) }); const renderEmpty = () => { viewer.snapshot = emptySnapshot(); viewer.selectedTutorialId = null; viewer.compactSessionTutorialIds = []; viewer.requestUpdate(); }; renderEmpty(); clearInterval(window.__compactEmptyKeeper); window.__compactEmptyKeeper = setInterval(renderEmpty, 100); await waitFor(async () => { await viewer.updateComplete; return root.querySelector('.compact-empty-message') && root.querySelector('[data-testid=tutorial-compact-got-it]'); }); const empty = root.querySelector('.compact-empty-message'); const emptyStyle = getComputedStyle(empty); if (emptyStyle.textAlign !== 'left') throw new Error('Expected compact empty message to be left aligned, got ' + emptyStyle.textAlign); const emptyLayout = assertFooter('empty'); return { contentLayout, emptyLayout, emptyAlign: emptyStyle.textAlign, emptyText: empty.textContent.trim() }; })()" in the webview for 25 seconds
