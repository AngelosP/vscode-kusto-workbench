  Scenario: Browse all close stays top-right in wide width
    When I resize the Dev Host to 1040 by 720
    And I execute command "kusto.openTutorials"
    And I wait for "kw-tutorial-viewer" in the webview for 25 seconds
    And I evaluate "(async () => { const sleep = ms => new Promise(resolve => setTimeout(resolve, ms)); const waitFor = async predicate => { for (let attempt = 0; attempt < 120; attempt++) { const value = await predicate(); if (value) return value; await sleep(100); } throw new Error('Timed out waiting for wide standard layout'); }; const viewer = await waitFor(() => document.querySelector('kw-tutorial-viewer')); const root = viewer.shadowRoot; await waitFor(async () => { await viewer.updateComplete; return viewer.snapshot && root.querySelector('[data-testid=tutorial-viewer-mode-standard]'); }); const frame = root.querySelector('.standard-frame'); const refresh = root.querySelector('.standard-refresh'); const close = root.querySelector('[data-testid=tutorial-standard-dismiss]'); if (!frame || !refresh || !close) throw new Error('Missing standard wide layout elements'); const frameRect = frame.getBoundingClientRect(); const refreshRect = refresh.getBoundingClientRect(); const closeRect = close.getBoundingClientRect(); if (Math.abs(frameRect.right - closeRect.right) > 24 || closeRect.top - frameRect.top > 24) throw new Error('Close should sit in the wide top-right corner. frame=' + JSON.stringify(frameRect.toJSON()) + ' close=' + JSON.stringify(closeRect.toJSON())); if (closeRect.left - refreshRect.right < 40) throw new Error('Close should not sit next to refresh in wide layout. refresh=' + JSON.stringify(refreshRect.toJSON()) + ' close=' + JSON.stringify(closeRect.toJSON())); return { frame: frameRect.toJSON(), refresh: refreshRect.toJSON(), close: closeRect.toJSON() }; })()" in the webview for 25 seconds
    Then I take a screenshot "02-standard-wide-close"

