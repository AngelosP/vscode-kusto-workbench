    When I resize the Dev Host to 560 by 720
    And I execute command "kusto.openTutorials"
    And I wait for "kw-tutorial-viewer" in the webview for 25 seconds
    And I evaluate "(async () => { const sleep = ms => new Promise(resolve => setTimeout(resolve, ms)); const waitFor = async predicate => { for (let attempt = 0; attempt < 120; attempt++) { const value = await predicate(); if (value) return value; await sleep(100); } throw new Error('Timed out waiting for standard action layout'); }; const viewer = await waitFor(() => document.querySelector('kw-tutorial-viewer')); const root = viewer.shadowRoot; await waitFor(async () => { await viewer.updateComplete; return viewer.snapshot && root.querySelector('[data-testid=tutorial-viewer-mode-standard]'); }); const base = viewer.snapshot; const first = base.catalog.content[0]; const content = Array.from({ length: 24 }, (_, index) => ({ ...first, id: 'e2e-tip-' + index, displayName: 'E2E tutorial item ' + String(index + 1).padStart(2, '0'), unseen: index < 8 })); viewer.snapshot = { ...base, selectedTutorialId: content[0].id, catalog: { ...base.catalog, content }, preferences: base.preferences.map(preference => ({ ...preference, unseenCount: 8 })) }; viewer.selectedTutorialId = content[0].id; viewer.requestUpdate(); await waitFor(async () => { await viewer.updateComplete; return root.querySelectorAll('[data-testid=tutorial-item]').length >= 24; }); const info = root.querySelector('.status-info'); if (info) throw new Error('Standard status info icon should be removed'); const refresh = root.querySelector('.standard-refresh'); const close = root.querySelector('[data-testid=tutorial-standard-dismiss]'); const toolbar = root.querySelector('.toolbar-actions'); if (!refresh || !close || !toolbar) throw new Error('Missing standard toolbar buttons'); const refreshRect = refresh.getBoundingClientRect(); const closeRect = close.getBoundingClientRect(); if (refreshRect.right > closeRect.left + 1) throw new Error('Refresh and close overlap or are reversed. refresh=' + JSON.stringify(refreshRect.toJSON()) + ' close=' + JSON.stringify(closeRect.toJSON())); if (!refresh.title.includes('Refresh catalog') || !refresh.title.includes('Catalog:')) throw new Error('Refresh tooltip should include status text, got ' + refresh.title); const gotIt = root.querySelector('[data-testid=tutorial-standard-got-it]'); const compact = root.querySelector('[data-testid=tutorial-mode-compact]'); const mute = root.querySelector('[data-testid=tutorial-standard-mute]'); if (!gotIt || !compact || !mute) throw new Error('Missing standard footer actions'); const compactStyle = getComputedStyle(compact); if (compactStyle.backgroundColor === getComputedStyle(gotIt).backgroundColor) throw new Error('Compact secondary button should not use primary background'); const list = root.querySelector('[data-testid=tutorial-list]'); if (!list || list.getAttribute('data-overlay-scroll') !== 'x:hidden y:scroll visibility:visible autoHide:never') throw new Error('Tutorial list is not configured for visible overlay scrolling'); const verticalScrollbar = await waitFor(() => { const listRect = list.getBoundingClientRect(); const candidates = Array.from(root.querySelectorAll('.os-scrollbar-vertical')); for (const scrollbar of candidates) { const rect = scrollbar.getBoundingClientRect(); const style = getComputedStyle(scrollbar); const handle = scrollbar.querySelector('.os-scrollbar-handle'); const handleRect = handle ? handle.getBoundingClientRect() : null; const besideList = Math.abs(rect.right - listRect.right) <= 20 && rect.bottom > listRect.top && rect.top < listRect.bottom; if (besideList && handle && handleRect && rect.height > 20 && handleRect.height > 8 && style.visibility === 'visible' && Number(style.opacity) > 0) return scrollbar; } return null; }); const initialScrollTop = list.scrollTop; list.focus(); list.dispatchEvent(new KeyboardEvent('keydown', { key: 'ArrowDown', bubbles: true })); await waitFor(async () => { await viewer.updateComplete; return viewer.selectedTutorialId === 'e2e-tip-1'; }); for (let i = 0; i < 18; i++) list.dispatchEvent(new KeyboardEvent('keydown', { key: 'ArrowDown', bubbles: true })); await waitFor(async () => { await viewer.updateComplete; return viewer.selectedTutorialId === 'e2e-tip-19'; }); const active = root.querySelector('[data-tutorial-id=e2e-tip-19]'); active.focus(); active.scrollIntoView({ block: 'nearest' }); await sleep(50); if (document.activeElement !== viewer || viewer.shadowRoot.activeElement !== active) throw new Error('Keyboard navigation should preserve focus on the active tutorial item'); if (list.scrollHeight <= list.clientHeight) throw new Error('Tutorial list should be scrollable in adaptive width'); if (list.scrollTop <= initialScrollTop) throw new Error('Tutorial list did not scroll after keyboard navigation'); gotIt.click(); return { refresh: refreshRect.toJSON(), close: closeRect.toJSON(), scrollbar: verticalScrollbar.className, list: { scrollTop: list.scrollTop, scrollHeight: list.scrollHeight, clientHeight: list.clientHeight }, active: viewer.selectedTutorialId, footerButtons: Array.from(root.querySelectorAll('.standard-footer button')).map(button => button.dataset.testid || button.className) }; })()" in the webview for 25 seconds
