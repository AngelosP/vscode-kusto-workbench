    And I evaluate "(() => { const viewer = document.querySelector('kw-tutorial-viewer'); const root = viewer.shadowRoot; const agent = root.querySelector('[data-testid=tutorial-category-row][data-category-id=agent] .category-main'); if (!agent) throw new Error('missing Agent category row'); agent.click(); return viewer.updateComplete.then(() => { const first = root.querySelector('[data-testid=tutorial-item]'); if (!first) throw new Error('missing first filtered tutorial'); first.click(); return viewer.updateComplete.then(() => { root.querySelector('[data-testid=tutorial-mode-focused]').click(); return viewer.updateComplete.then(() => { if (!root.querySelector('[data-testid=tutorial-viewer-mode-focused]')) throw new Error('focused mode did not render'); const next = root.querySelector('[data-testid=tutorial-next]'); if (!next || next.disabled) throw new Error('focused next navigation unavailable'); next.click(); return viewer.updateComplete.then(() => { if (!root.textContent.includes('Refine')) throw new Error('focused next navigation did not advance within category'); const standard = root.querySelector('[data-testid=tutorial-mode-standard]'); if (!standard) throw new Error('missing standard mode button'); return 'focused mode verified'; }); }); }); }); })()" in the webview
